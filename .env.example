# ─── tg-dex-miniapp .env.example ─────────────────────────────────────────────
# Copy to .env and fill in values before running.
# NEVER commit .env to version control.

# ─── Required ────────────────────────────────────────────────────────────────
DATABASE_URL=mysql://user:pass@host:3306/dex_miniapp
JWT_SECRET=<run: openssl rand -hex 32>
TELEGRAM_BOT_TOKEN=<from @BotFather>
TELEGRAM_BOT_USERNAME=<your_bot_username, no @>
OWNER_OPEN_ID=<your Telegram numeric user ID>
OWNER_NAME=<your display name>
NODE_ENV=production
PORT=3000

# ─── Feature flags ───────────────────────────────────────────────────────────
# FEATURE_MODE: "demo" (stub venue + simulated tx) | "production" (live venue)
FEATURE_MODE=demo
# Set to "true" only after testnet rehearsal passes
FEATURE_MAINNET=false

# ─── Settlement Venue (pluggable) ────────────────────────────────────────────
# Your settlement venue REST API root.
# Default adapter: see server/lib/dex/adapter.ts — plug in any CLOB/RFQ venue.
# Testnet:  https://api-testnet.your-venue.example/api/v1
# Mainnet:  https://api.your-venue.example/api/v1
DEX_API_BASE=https://api-testnet.your-venue.example/api/v1


# ─── News Feed (optional) ────────────────────────────────────────────────────
# URL for the news API (tRPC-style: returns { result: { data: { json: [...] } } })
# Leave blank to disable the news tab (returns empty article list).
NEWS_API_URL=
# Base URL for article links (appended with /{slug})
NEWS_BASE_URL=
# Treasury/fee-recipient wallet for on-chain promotion fees
APP_TREASURY_WALLET=

# ─── Blockchain RPC ──────────────────────────────────────────────────────────
SEPOLIA_RPC_URL=
MAINNET_RPC_URL=
# Block explorer base URL — default: etherscan.io / sepolia.etherscan.io
# Override to use a different chain's explorer
EXPLORER_BASE=

# ─── Auth Provider: Privy (pluggable) ────────────────────────────────────────
# Leave blank to use Telegram-cookie session auth (no external provider).
# Set PRIVY_APP_ID from your Privy dashboard to enable embedded wallets.
PRIVY_APP_ID=
VITE_PRIVY_APP_ID=
VITE_FEATURE_PRIVY_AUTH=false

# ─── Fiat Ramp: Peer / zkP2P (pluggable) ─────────────────────────────────────
# OFF by default. Peer settles on Base mainnet (chain 8453) in real USDC.
FEATURE_PEER=false
# "production" | "preproduction" | "staging"
PEER_RUNTIME_ENV=production
# Base chain RPC (required for on-chain ramp actions)
PEER_BASE_RPC_URL=
# Optional zkP2P curator API key (enriches quotes)
PEER_API_KEY=
# Optional zkP2P API host override
PEER_BASE_API_URL=
# Referrer fee recipient and basis points (e.g. 30 = 0.3%)
PEER_REFERRER_FEE_RECIPIENT=
PEER_REFERRER_FEE_BPS=0

# ─── Client (Vite) ───────────────────────────────────────────────────────────
VITE_APP_ID=dex-miniapp
VITE_FEATURE_MODE=demo
# Bot username for deep links (no @)
VITE_TG_BOT_USERNAME=your_bot_username

# ─── Telegram webhook ────────────────────────────────────────────────────────
# Leave blank to use long-polling (simpler for local dev)
BOT_WEBHOOK_URL=

# ─── Storage (optional, pluggable) ───────────────────────────────────────────
# S3-compatible storage for media uploads. Leave blank for local disk fallback.
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=

# ─── Demo seed shops (testnet only) ──────────────────────────────────────────
# BIP-39 mnemonic to derive deterministic, fundable demo money-changer wallets.
# If unset, the auto-seed falls back to random (non-fundable) wallets — fine for
# pure UI demos. The server auto-seeds 22 changers on boot; re-seed manually with
# POST /internal/seed/run.
SEED_MNEMONIC=
